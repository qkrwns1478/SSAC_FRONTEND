{
  "name": "ssac-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "layers": "depcruise src --config .dependency-cruiser.cjs",
    "validate": "npm run typecheck && npm run lint && npm run format:check && npm run layers && npm run build",
    "scaffold": "node scripts/scaffold.js",
    "prepare": "git config core.hooksPath .githooks || true",
    "sync:api": "./scripts/sync-api.sh"
  },
  "dependencies": {
    "next": "^16.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dependency-cruiser": "^16",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.5.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
